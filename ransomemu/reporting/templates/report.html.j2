<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RansomEmu Report — {{ timestamp }}</title>
<style>
  :root { --bg: #0f0f23; --card: #1a1a3e; --accent: #e94560; --green: #00d26a;
           --red: #ff6b6b; --text: #e0e0e0; --muted: #8892b0; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg);
          color: var(--text); padding: 2rem; }
  h1 { color: var(--accent); margin-bottom: 0.5rem; }
  .subtitle { color: var(--muted); margin-bottom: 2rem; }
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem; margin-bottom: 2rem; }
  .stat-card { background: var(--card); border-radius: 12px; padding: 1.5rem;
                border-left: 4px solid var(--accent); }
  .stat-value { font-size: 2rem; font-weight: bold; color: var(--accent); }
  .stat-label { color: var(--muted); font-size: 0.9rem; }
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before { content: ''; position: absolute; left: 0.5rem; top: 0;
                       bottom: 0; width: 2px; background: var(--accent); opacity: 0.3; }
  .event { background: var(--card); border-radius: 8px; padding: 1rem 1.5rem;
            margin-bottom: 0.75rem; position: relative; }
  .event::before { content: ''; position: absolute; left: -1.75rem; top: 1.2rem;
                    width: 10px; height: 10px; border-radius: 50%;
                    background: var(--accent); }
  .event.success::before { background: var(--green); }
  .event.error::before { background: var(--red); }
  .event-time { color: var(--muted); font-size: 0.8rem; }
  .event-type { display: inline-block; padding: 2px 8px; border-radius: 4px;
                 font-size: 0.75rem; font-weight: bold; background: var(--accent);
                 color: white; margin-right: 0.5rem; }
  .event-target { color: var(--accent); font-weight: bold; }
</style>
</head>
<body>
<h1>🔒 RansomEmu Report</h1>
<p class="subtitle">Generated: {{ timestamp }}</p>

<div class="stats">
  <div class="stat-card">
    <div class="stat-value">{{ total_events }}</div>
    <div class="stat-label">Total Events</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{{ lateral_moves }}</div>
    <div class="stat-label">Lateral Moves</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{{ success_count }}</div>
    <div class="stat-label">Successful</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{{ success_rate }}%</div>
    <div class="stat-label">Success Rate</div>
  </div>
</div>

<h2 style="margin-bottom: 1rem;">📋 Event Timeline</h2>
<div class="timeline">
{% for evt in events %}
  <div class="event {{ evt.css_class }}">
    <span class="event-type">{{ evt.type }}</span>
    {% if evt.target %}
    <span class="event-target">{{ evt.target }}</span>
    {% endif %}
    <span class="event-time">{{ evt.timestamp }}</span>
    <p style="margin-top: 0.5rem;">{{ evt.message }}</p>
  </div>
{% endfor %}
</div>
</body>
</html>
